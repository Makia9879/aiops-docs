{
  "name": "@makia9879/aiops",
  "version": "0.1.2",
  "description": "Executable AIOps governance workspace bootstrap CLI.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "aiops": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepare-package": "node scripts/prepare-package.mjs",
    "prepack": "npm run build && npm run prepare-package",
    "prepublishOnly": "npm run check"
  },
  "files": [
    "dist",
    "assets/skills",
    "README.md"
  ],
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
